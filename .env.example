# DoctorAI local development environment template.
# Copy this file to .env.local and replace every placeholder value.

DATABASE_URL="postgresql://doctorai_user:replace-with-password@your-postgres-host.postgres.database.azure.com:5432/doctorai?sslmode=require"
APP_BASE_URL="http://localhost:3000"
AUTH_SECRET="replace-with-a-long-random-auth-secret"
# Use "true" only for local/demo environments. Set "false" in hosted production.
ENABLE_DEMO_LOGIN="true"

AZURE_SPEECH_KEY="replace-with-your-azure-speech-key"
AZURE_SPEECH_ENDPOINT="https://your-speech-region.api.cognitive.microsoft.com"
AZURE_SPEECH_REGION="your-speech-region"

AZURE_OPENAI_KEY="replace-with-your-azure-openai-key"
AZURE_OPENAI_ENDPOINT="https://your-openai-resource.openai.azure.com"
AZURE_OPENAI_SUMMARY_DEPLOYMENT="your-summary-deployment-name"
AZURE_OPENAI_NORMALIZATION_DEPLOYMENT="your-optional-cheaper-normalization-deployment-name"

ACS_CONNECTION_STRING="endpoint=https://your-acs-resource.communication.azure.com/;accesskey=replace-with-your-acs-access-key"
ACS_SENDER_ADDRESS="DoNotReply@your-verified-domain.example"
